#!/usr/bin/env bash
#
# pre-commit: two blocking gates for this repo.
#   (a) em-dash gate: block any staged ADDED line containing an em dash or en dash.
#   (b) bleed gate:    block any staged ADDED line containing a private tell.
#
# Both scan only the staged additions (what this commit would introduce), so an
# existing line elsewhere never blocks an unrelated commit. Install with
# .githooks/install.sh (sets core.hooksPath). See method/09-safety-nets.md for
# why these exist: each is a past mistake turned into a guard.
#
# Portable: uses POSIX awk only (no gawk 3-arg match), so it runs on the BSD awk
# that ships with macOS as well as on gawk.

set -euo pipefail

# Emit every staged ADDED line as "path:newlineno: content".
# -U0 means no context lines, so every non-header line in a hunk that starts with
# '+' is an addition and advances the new-file line counter; '-' lines do not.
added_lines() {
  # NO self-exclusions. The gate files are scanned like everything else: the
  # denylist lives outside the tree (denylist.local, gitignored), so a match
  # in these files is a real leak, not the pattern matching itself. An earlier
  # version embedded the denylist here, which made the leak scanner ITSELF
  # the leak; an adversarial audit caught it. Do not regress this.
  git diff --cached --unified=0 --no-color -- . | awk '
    /^\+\+\+ / {
      file=$0
      sub(/^\+\+\+ b\//,"",file)
      sub(/^\+\+\+ /,"",file)
      next
    }
    /^@@ / {
      plus=$3            # e.g. "+3,4" or "+3"
      sub(/^\+/,"",plus)
      sub(/,.*/,"",plus)
      ln=plus+0
      next
    }
    /^\+/ {
      print file ":" ln ": " substr($0,2)
      ln++
    }
  '
}

fail=0
stream="$(added_lines || true)"

# --- Gate (a): em dash (U+2014) and en dash (U+2013) ---
# Built from byte escapes so this file never contains the characters it bans
# (the hook scans itself now; a literal dash here would block committing the
# hook). UTF-8: em dash e2 80 94, en dash e2 80 93.
EMDASH="$(printf '\342\200\224')"
ENDASH="$(printf '\342\200\223')"
emdash_hits="$(printf '%s\n' "$stream" | grep -F -e "$EMDASH" -e "$ENDASH" || true)"
if [ -n "$emdash_hits" ]; then
  echo "BLOCKED: staged change adds an em dash or en dash:"
  printf '%s\n' "$emdash_hits" | sed 's/^/  /'
  echo ""
  echo "Use a period, comma, colon, or parentheses instead. This guard exists"
  echo "because dashes slip in by hand and we remove them by policy, not by eye."
  fail=1
fi

# --- Gate (b): private tells (bleed check) ---
# The terms live in .githooks/denylist.local (gitignored), one per line,
# comments allowed. Missing or empty denylist REFUSES the commit: a bleed
# gate with nothing to check silently passes everything, which is the worst
# failure mode a guard can have. Copy denylist.example and fill it in.
denylist_file="$(git rev-parse --show-toplevel)/.githooks/denylist.local"
if [ ! -f "$denylist_file" ]; then
  echo "BLOCKED: .githooks/denylist.local is missing."
  echo "Copy .githooks/denylist.example to .githooks/denylist.local and fill in"
  echo "your real private terms (it is gitignored, never committed)."
  exit 1
fi
DENYLIST="$(grep -v '^\s*#' "$denylist_file" | grep -v '^\s*$' | paste -sd'|' -)"
if [ -z "$DENYLIST" ]; then
  echo "BLOCKED: .githooks/denylist.local has no terms in it."
  exit 1
fi

bleed_hits="$(printf '%s\n' "$stream" | grep -iE "$DENYLIST" || true)"
if [ -n "$bleed_hits" ]; then
  echo "BLOCKED: staged change adds a private tell (bleed check):"
  printf '%s\n' "$bleed_hits" | sed 's/^/  /'
  echo ""
  echo "This is a public-bound repo. Scrub the private codename, path, key, or"
  echo "product name before committing. See scripts/leak-audit.sh for the full"
  echo "tree scan and method/09-safety-nets.md for why this guard exists."
  fail=1
fi

# --- Gate (c): prompt sync (accuracy) ---
# The hero prompt lives in two places: embedded in README.md and raw in
# prompt.txt. If this commit touches either, the STAGED copies must be
# byte-identical. Compares staged content (git show :path), not the working
# tree, so what is checked is exactly what would land.
if git diff --cached --name-only | grep -qE '^(README\.md|prompt\.txt)$'; then
  staged_readme_prompt="$(git show :README.md 2>/dev/null | awk '/^```$/{if(inblk){exit}} /^```/{inblk=1;next} inblk{print}')"
  staged_prompt="$(git show :prompt.txt 2>/dev/null)"
  if [ "$staged_readme_prompt" != "$staged_prompt" ]; then
    echo "BLOCKED: README.md's embedded prompt and prompt.txt would land out of sync."
    echo "Edit one, mirror the other, re-stage both. scripts/release-check.sh"
    echo "shows the diff. Two drifting copies of the hero prompt is the most"
    echo "embarrassing inaccuracy this repo could ship."
    fail=1
  fi
fi

if [ "$fail" -ne 0 ]; then
  echo ""
  echo "Commit rejected. Fix the lines above and re-commit."
  exit 1
fi

exit 0
